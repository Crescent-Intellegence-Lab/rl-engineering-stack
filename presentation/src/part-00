const SH = pptx.ShapeType;

function addTitle(slide, title, subtitle='') {
  slide.addText(title, { x: 0.48, y: 0.33, w: 12.2, h: 0.42, fontFace: 'Arial', fontSize: 26, bold: true, color: C.navy, margin: 0 });
  if (subtitle) {
    slide.addText(subtitle, { x: 0.5, y: 0.82, w: 12.1, h: 0.28, fontFace: 'Arial', fontSize: 11.5, color: C.muted, margin: 0 });
  }
}

function addPill(slide, text, x, y, w, color, fill) {
  slide.addShape(SH.roundRect, { x, y, w, h: 0.32, rectRadius: 0.08, fill: { color: fill }, line: { color: fill } });
  slide.addText(text, { x, y: y + 0.035, w, h: 0.2, fontFace: 'Arial', fontSize: 9.5, bold: true, align: 'center', color, margin: 0 });
}

function addCard(slide, x, y, w, h, opts={}) {
  const fill = opts.fill || C.white;
  const line = opts.line || C.line;
  slide.addShape(SH.roundRect, { x, y, w, h, rectRadius: 0.06, fill: { color: fill }, line: { color: line, width: opts.lineWidth || 1 } });
}

function addBulletList(slide, items, x, y, w, h, opts={}) {
  const runs = [];
  items.forEach((t, i) => {
    runs.push({
      text: t,
      options: {
        bullet: { indent: opts.indent || 13 },
        hanging: opts.hanging || 3,
        breakLine: true,
        color: opts.color || C.text,
        fontSize: opts.fontSize || 16
      }
    });
  });
  slide.addText(runs, { x, y, w, h, fontFace: 'Arial', valign: 'top', margin: 0.04, paraSpaceAfterPt: opts.paraSpaceAfterPt || 7, breakLine: false });
}

function addSource(slide, text) {
  slide.addText(text, { x: 0.52, y: 6.86, w: 12.15, h: 0.16, fontFace: 'Arial', fontSize: 7.6, italic: true, color: '7B8798', margin: 0 });
}

function addArrow(slide, x1, y1, x2, y2, color=C.muted, width=2.2) {
  slide.addShape(SH.line, { x: x1, y: y1, w: x2-x1, h: y2-y1, line: { color, width, beginArrowType: 'none', endArrowType: 'triangle' } });
}

function addNotes(slide, text) {
  slide.addNotes(text);
}

